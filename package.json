{
  "name": "aem-agent-extension",
  "version": "1.0.0",
  "description": "An AI-powered AEM development agent that bridges the browser context (WebMCP) with the AEM JCR and CXForge administrative tools.",
  "main": "playwright.config.js",
  "directories": {
    "test": "tests"
  },
  "scripts": {
    "test": "playwright test",
    "test:unit": "playwright test --grep-invert \"integration|AEM API|Sling|JCR|Content Fragment|Ghostwriter|Environment Diff\"",
    "build": "zip -r aem-agent-extension.zip . --exclude='*.git*' --exclude='node_modules/*' --exclude='test-results/*' --exclude='*.zip'"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "devDependencies": {
    "@playwright/test": "^1.59.1"
  }
}
